# Copy to `.env` on the deployment host (next to docker-compose.prod.yml).

LETSENCRYPT_EMAIL=ops@solivio.ai

# Pin to a commit SHA for reproducible deploys; "latest" for fast iteration.
IMAGE_TAG=latest

POSTGRES_DB=solivio
POSTGRES_USER=solivio
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://solivio:change-me@db:5432/solivio

OPENAI_API_KEY=

BETTER_AUTH_URL=https://demo.solivio.ai
NEXT_PUBLIC_BETTER_AUTH_URL=https://demo.solivio.ai

# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

AUTH_ENABLED=true
AUTH_SIGNUP_ENABLED=true
AUTH_CREDENTIALS_ENABLED=true
AUTH_SSO_ENABLED=false
