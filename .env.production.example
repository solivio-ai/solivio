# Copy to `.env` on the deployment host (next to docker-compose.prod.yml).

APP_HOST=demo.solivio.ai
LETSENCRYPT_EMAIL=ops@solivio.ai

# Pin to a commit SHA for reproducible deploys; "latest" for fast iteration.
IMAGE_TAG=latest

POSTGRES_DB=solivio
POSTGRES_USER=solivio
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://solivio:change-me@db:5432/solivio

OPENAI_API_KEY=
# Per-role model overrides. Leave empty to use code defaults from
# apps/solivio/src/server/agents/modelConfig.ts (full/mini/nano per role).
OPENAI_MODEL_OFFER_GENERATION=
OPENAI_MODEL_OFFER_VALIDATION=
OPENAI_MODEL_OFFER_NAME=
OPENAI_MODEL_CHAT=
OPENAI_MODEL_PRODUCT_SEARCH=
# Empty = code default (text-embedding-3-large).
EMBEDDING_MODEL=

BETTER_AUTH_URL=https://demo.solivio.ai

# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

AUTH_ENABLED=true
AUTH_SIGNUP_ENABLED=true
AUTH_CREDENTIALS_ENABLED=true
AUTH_SSO_ENABLED=false
