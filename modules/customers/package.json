{
  "name": "@solivio/module-customers",
  "version": "0.1.0",
  "private": true,
  "description": "Customers and customer requests: data, services, import, and admin UI.",
  "type": "module",
  "solivio": {
    "module": true
  },
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@solivio/domain": "workspace:*",
    "@solivio/sdk": "workspace:*",
    "@solivio/ui": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": "*",
    "next-intl": "*",
    "react": "*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.2",
    "typescript": "^6.0.3"
  }
}
