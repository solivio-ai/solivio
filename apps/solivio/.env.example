DATABASE_URL=postgresql://solivio:solivio@localhost:5432/solivio
OPENAI_API_KEY=
# Per-role model overrides. Leave empty to use code defaults from
# src/server/agents/modelConfig.ts (full/mini/nano per role).
OPENAI_MODEL_OFFER_GENERATION=
OPENAI_MODEL_OFFER_VALIDATION=
OPENAI_MODEL_OFFER_NAME=
OPENAI_MODEL_CHAT=
OPENAI_MODEL_PRODUCT_SEARCH=
# Empty = code default (text-embedding-3-large).
EMBEDDING_MODEL=

# ── Better Auth ────────────────────────────────────────────────────────────────
# App URL used by Better Auth for redirects and CORS.
BETTER_AUTH_URL=http://localhost:3000

# Required in production — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Auth form options ──────────────────────────────────────────────────────────
# Set to false to remove the sign-up form (invite-only / admin-provisioned users).
AUTH_SIGNUP_ENABLED=true

# Role assigned to new sign-ups. Defaults to "admin" for easy local onboarding.
# Set to "user" in shared or production-like environments.
AUTH_SIGNUP_DEFAULT_ROLE=admin

# Set to false to hide email/password login and force SSO-only.
AUTH_CREDENTIALS_ENABLED=true

# Set to false to hide OAuth buttons and force credentials-only login.
AUTH_SSO_ENABLED=true

# ── OAuth providers ────────────────────────────────────────────────────────────
# Buttons appear automatically when CLIENT_ID is set (and AUTH_SSO_ENABLED is true).

# Google — https://console.cloud.google.com/
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID — https://entra.microsoft.com/
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
# Optional: restrict to a specific tenant. Omit or set "common" to allow any Microsoft account.
AUTH_MICROSOFT_TENANT_ID=common
