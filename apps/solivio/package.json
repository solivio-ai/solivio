{
  "name": "@solivio/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "db:check": "node scripts/check-drizzle-drift.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.mjs",
    "db:studio": "drizzle-kit studio --config src/generated/db/drizzle.studio.config.ts",
    "benchmark": "tsx --conditions=react-server benchmarks/run.ts",
    "benchmark:report": "tsx benchmarks/report.ts",
    "benchmark:readme": "tsx benchmarks/readme.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.70",
    "@ai-sdk/react": "^3.0.204",
    "@react-pdf/renderer": "^4.5.1",
    "@solivio/domain": "workspace:*",
    "@solivio/sdk": "workspace:*",
    "@solivio/theme": "workspace:*",
    "@solivio/ui": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@voltagent/core": "^2.7.7",
    "ai": "^6.0.202",
    "better-auth": "^1.6.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.3",
    "postcss": "^8.5.15",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.11.2",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "drizzle-kit": "^0.31.10",
    "server-only": "^0.0.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.3.0"
  }
}
