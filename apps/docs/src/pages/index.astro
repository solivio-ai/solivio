---
const links = [
  { href: "/guides/", label: "Guides" },
  { href: "/api/", label: "API Reference" },
];

const flow = ["Data", "AI", "Structured draft", "Review", "Send"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Solivio</title>
    <meta
      name="description"
      content="Solivio is an open-source AI system that transforms how B2B companies create offers."
    />
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:title" content="Solivio" />
    <meta
      property="og:description"
      content="Instead of building every quote manually, Solivio generates structured offer drafts based on your data — in seconds."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:image" content="/solivio-logo.png" />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      (() => {
        const storedTheme =
          typeof localStorage !== "undefined" && localStorage.getItem("starlight-theme");
        document.documentElement.dataset.theme = storedTheme === "dark" ? "dark" : "light";
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Solivio home">
        <img class="logo logo-light" src="/solivio-logo.png" alt="Solivio" width="180" height="60" />
        <img class="logo logo-dark" src="/solivio-logo-dark.png" alt="Solivio" width="180" height="60" />
      </a>
      <nav aria-label="Primary navigation">
        {links.map((link) => <a class="nav-button" href={link.href}>{link.label}</a>)}
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to dark mode"></button>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="landing-title">
        <div class="hero-copy">
          <p class="eyebrow">Open-source AI system</p>
          <h1 id="landing-title">Solivio</h1>
          <p>
            Instead of building every quote manually, Solivio generates structured offer drafts based
            on your data — in seconds.
          </p>
          <div class="landing-actions">
            {
              links.map((link, index) => (
                <a class:list={["landing-action", index === 0 ? "primary" : "secondary"]} href={link.href}>
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <section class="flow" aria-label="Solivio workflow">
        {flow.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{item}</strong>
          </article>
        ))}
      </section>
    </main>
    <script is:inline>
      (() => {
        const storageKey = "starlight-theme";
        const button = document.querySelector("[data-theme-toggle]");
        const getTheme = () => document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        const setTheme = (theme) => {
          document.documentElement.dataset.theme = theme;
          if (typeof localStorage !== "undefined") localStorage.setItem(storageKey, theme);
          if (button) button.setAttribute("aria-label", `Switch to ${theme === "dark" ? "light" : "dark"} mode`);
        };

        if (button) {
          button.addEventListener("click", () => {
            setTheme(getTheme() === "dark" ? "light" : "dark");
          });
          setTheme(getTheme());
        }
      })();
    </script>
  </body>
</html>

<style>
  @import "@solivio/theme";

  :global(html) {
    background: var(--solivio-color-background);
    color: var(--solivio-color-foreground);
    font-family: var(--solivio-font-sans);
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;
  }

  .site-header {
    align-items: center;
    background: var(--solivio-color-card);
    border-bottom: 1px solid var(--solivio-color-muted);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    min-height: 72px;
    padding: 0 24px;
  }

  .brand {
    align-items: center;
    display: inline-flex;
    min-width: 0;
  }

  .brand .logo {
    display: block;
    height: 44px;
    max-width: min(180px, 54vw);
    object-fit: contain;
    width: auto;
  }

  .brand .logo-dark {
    display: none;
  }

  :global(html[data-theme="dark"]) .brand .logo-light {
    display: none;
  }

  :global(html[data-theme="dark"]) .brand .logo-dark {
    display: block;
  }

  nav,
  .landing-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .nav-button,
  .landing-action,
  .theme-toggle {
    align-items: center;
    border: 1px solid var(--solivio-color-muted);
    border-radius: var(--solivio-radius);
    box-sizing: border-box;
    color: var(--solivio-color-foreground);
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  .theme-toggle {
    background: transparent;
    color: var(--solivio-color-muted-foreground);
    cursor: pointer;
    min-height: 40px;
    padding: 0;
    width: 40px;
  }

  .theme-toggle::before {
    border-radius: 999px;
    box-shadow: inset 5px -5px 0 0 currentColor;
    content: "";
    display: block;
    height: 16px;
    width: 16px;
  }

  :global(html[data-theme="dark"]) .theme-toggle::before {
    background: currentColor;
    box-shadow: 0 0 0 3px color-mix(in srgb, currentColor 30%, transparent);
  }

  .nav-button {
    min-height: 40px;
    padding: 0 14px;
  }

  .landing-action {
    min-height: 52px;
    padding: 0 18px;
  }

  .nav-button:hover,
  .landing-action.secondary:hover,
  .theme-toggle:hover {
    background: var(--solivio-color-muted);
    color: var(--solivio-color-foreground);
  }

  .hero {
    align-items: center;
    display: grid;
    min-height: calc(100svh - 200px);
    padding: 48px 24px;
  }

  .hero-copy {
    display: grid;
    gap: 18px;
    margin: 0 auto;
    max-width: 860px;
    text-align: center;
    width: 100%;
  }

  .eyebrow {
    color: var(--solivio-color-primary);
    font-size: 13px;
    font-weight: 850;
    letter-spacing: 0;
    margin: 0;
    text-transform: uppercase;
  }

  .hero h1 {
    font-size: clamp(56px, 10vw, 116px);
    line-height: 0.95;
    margin: 0;
  }

  .hero p {
    color: var(--solivio-color-muted-foreground);
    font-size: clamp(18px, 2.4vw, 28px);
    line-height: 1.45;
    margin: 0 auto;
    max-width: 780px;
  }

  .landing-actions {
    justify-content: center;
  }

  .landing-action.primary {
    background: var(--solivio-color-primary);
    border-color: var(--solivio-color-primary);
    color: var(--solivio-color-primary-foreground);
  }

  .landing-action.primary:hover {
    background: var(--solivio-color-primary-hover);
    border-color: var(--solivio-color-primary-hover);
  }

  .flow {
    border-top: 1px solid var(--solivio-color-muted);
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .flow article {
    background: var(--solivio-color-card);
    display: grid;
    gap: 8px;
    min-height: 112px;
    padding: 18px;
  }

  .flow span {
    color: var(--solivio-color-primary);
    font-size: 13px;
    font-weight: 800;
  }

  .flow strong {
    font-size: 16px;
    line-height: 1.25;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
    }

    nav {
      width: 100%;
    }

    .hero {
      min-height: auto;
      padding: 44px 16px;
    }

    .nav-button {
      min-height: 44px;
      padding: 0 14px;
    }

    .landing-action {
      min-height: 60px;
      padding: 0 18px;
    }

    .flow {
      grid-template-columns: 1fr;
    }
  }
</style>
