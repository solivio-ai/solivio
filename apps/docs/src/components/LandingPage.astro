      </section>

      <section class="border-t border-border px-4 py-16 sm:px-6 lg:px-14 lg:py-20" aria-label={labels.nextSteps}>
        <div class="mx-auto grid max-w-[94rem] gap-3 lg:grid-cols-2">
          <article class="grid gap-5 rounded-lg border border-primary/35 bg-primary/10 p-5 sm:grid-cols-[auto_1fr] sm:p-6" data-reveal>
            <div class="flex size-14 items-center justify-center rounded-lg bg-primary text-primary-foreground" aria-hidden="true">
