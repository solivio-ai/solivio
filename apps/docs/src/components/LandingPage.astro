---
import type { LandingContent } from "../landing/content";
import LandingDocumentHead from "./landing/LandingDocumentHead.astro";
import LandingFooter from "./landing/LandingFooter.astro";
import LandingHeader from "./landing/LandingHeader.astro";
import LandingInteractions from "./landing/LandingInteractions.astro";
import LandingMainSections from "./landing/LandingMainSections.astro";
import LandingSkipLink from "./landing/LandingSkipLink.astro";
import { getLandingLabels } from "./landing/shared";
import "../styles/landing.css";

interface Props {
  page: LandingContent;
}

const { page } = Astro.props;
const labels = getLandingLabels(page);
---

<!doctype html>
<html lang={page.lang}>
  <LandingDocumentHead page={page} />
  <body class="bg-background font-sans text-foreground antialiased">
    <LandingSkipLink label={labels.skipToContent} />

    <LandingHeader page={page} labels={labels} />

    <LandingMainSections page={page} labels={labels} />

    <LandingFooter page={page} labels={labels} />

    <LandingInteractions />
  </body>
</html>
