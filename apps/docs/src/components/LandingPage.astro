          <a class="text-sm text-muted-foreground hover:text-foreground" href={deraveUrl} target="_blank" rel="noopener noreferrer">Derave</a>
          <a class="text-sm text-muted-foreground hover:text-foreground" href="#main">{labels.footerTop}</a>
        </nav>
