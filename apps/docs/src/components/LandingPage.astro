---
import { deraveUrl, githubUrl, siteOrigin, type LandingContent } from "../landing/content";
import "../styles/landing.css";

type Link = {
  href: string;
  label: string;
  external?: boolean;
};

interface Props {
  page: LandingContent;
}

const { page } = Astro.props;
const isPolish = page.locale === "pl";

const absoluteUrl = (path: string) => new URL(path, siteOrigin).toString();
const linkAttrs = (link: Link) =>
  link.external ? { target: "_blank", rel: "noopener noreferrer" } : {};

const canonical = absoluteUrl(page.path);
const englishUrl = absoluteUrl("/");
const polishUrl = absoluteUrl("/pl/");
const ogImage = absoluteUrl("/media/solivio-promo-poster.png");
const releaseLabel = "v0.1.0";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Solivio",
    url: siteOrigin,
    inLanguage: page.lang,
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Derave Software",
    url: deraveUrl,
    sameAs: [githubUrl],
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Solivio",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Self-hosted web application",
    url: siteOrigin,
    codeRepository: githubUrl,
    license: "https://opensource.org/licenses/MIT",
    programmingLanguage: "TypeScript",
    isAccessibleForFree: true,
    description: page.description,
  },
];

const docsLinks = [
  { href: "/guides/getting-started/", label: page.hero.primary.label },
  { href: "/guides/features/", label: page.capabilities.link.label },
  { href: "/guides/modules/", label: page.architecture.link.label },
  { href: "/guides/extending/", label: page.modules.link.label },
  { href: "/api/", label: "API" },
];

const sourceSystems = isPolish
  ? ["CRM", "ERP", "E-commerce", "E-mail", "Excel", "PDF", "Wewnętrzne API"]
  : ["CRM", "ERP", "Ecommerce", "Email", "Excel", "PDF", "Internal APIs"];
const destinationSystems = isPolish
  ? ["CRM", "ERP", "E-commerce", "PDF", "BI", "Niestandardowe API"]
  : ["CRM", "ERP", "Ecommerce", "PDF", "BI", "Custom API"];
const solivioPipeline = isPolish
  ? ["Przyjęcie", "Ekstrakcja", "Dopasowanie", "Szkic", "Weryfikacja"]
  : ["Intake", "Extraction", "Matching", "Draft", "Review"];
const productSignals = [
  {
    label: isPolish ? "Pozycji w szkicu" : "Draft lines",
    value: String(page.hero.offerRows.length),
  },
  {
    label: isPolish ? "Etap" : "Stage",
    value: page.hero.offerStatus,
  },
  {
    label: isPolish ? "Wynik" : "Output",
    value: "PDF",
  },
];
const heroRail = [
  {
    title: isPolish ? "Kod open source" : "Open source",
    body: isPolish
      ? "MIT, lokalne uruchomienie i kod do przejrzenia."
      : "MIT, local setup, and inspectable source.",
  },
  {
    title: isPolish ? "Samodzielny hosting" : "Self-hosted",
    body: isPolish
      ? "Docker, Postgres i brak vendor lock-in."
      : "Docker, Postgres, and no vendor lock-in.",
  },
  {
    title: isPolish ? "Dla złożonych procesów" : "Built for complexity",
    body: isPolish
      ? "Wielopozycyjne zapytania i duże katalogi."
      : "Multi-line inquiries and large catalogs.",
  },
  {
    title: isPolish ? "Dla deweloperów" : "Developer first",
    body: isPolish
      ? "TypeScript, Next.js, Drizzle i moduły."
      : "TypeScript, Next.js, Drizzle, and modules.",
  },
];

const labels = {
  skipToContent: isPolish ? "Przejdź do treści" : "Skip to content",
  home: isPolish ? "Strona główna Solivio" : "Solivio home",
  primaryNavigation: isPolish ? "Główna nawigacja" : "Primary navigation",
  primaryActions: isPolish ? "Główne akcje" : "Primary actions",
  projectFacts: isPolish ? "Informacje o projekcie" : "Project facts",
  productPreview: isPolish ? "Podgląd produktu Solivio" : "Solivio product preview",
  nextSteps: isPolish ? "Następne kroki" : "Next steps",
  announcement: isPolish
    ? "Uruchom lokalnie, przejrzyj architekturę i sprawdź proces od zapytania do oferty"
    : "Run locally, inspect the architecture, and review the inquiry-to-quote workflow",
  quickStart: isPolish ? "Szybki start" : "Quick start",
  copy: isPolish ? "Kopiuj" : "Copy",
  copied: isPolish ? "Skopiowano" : "Copied",
  rawInquiry: isPolish ? "Surowe zapytanie" : "Raw inquiry",
  extractedSummary: isPolish ? "Ekstrakcja" : "Extracted summary",
  productMatches: isPolish ? "Dopasowania katalogu" : "Catalog matches",
  confidence: isPolish ? "Pewność" : "Confidence",
  generated: isPolish ? "Wygenerowany" : "Generated",
  inReview: isPolish ? "W weryfikacji" : "In review",
  accepted: isPolish ? "PDF" : "PDF",
  sourceTrail: isPolish ? "Ścieżka decyzyjna" : "Decision trail",
  architectureCaption: isPolish
    ? "Istniejące systemy → Solivio → zespół sprzedaży"
    : "Existing systems → Solivio → sales team",
  moduleStatus: isPolish ? "Typ" : "Surface",
  operatorLink: isPolish ? "Przejdź do przewodnika wdrożenia" : "Open deployment guide",
  footerTop: isPolish ? "Do góry" : "Back to top",
};

const buttonBaseClass =
  "inline-flex h-10 shrink-0 items-center justify-center gap-2 whitespace-nowrap rounded-lg border border-transparent px-4 text-sm font-semibold transition-all outline-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:translate-y-px";
const buttonPrimaryClass = `${buttonBaseClass} bg-primary text-primary-foreground shadow-[0_12px_30px_rgba(246,194,21,0.28)] hover:bg-primary/85`;
const buttonDarkClass = `${buttonBaseClass} bg-foreground text-background hover:bg-foreground/85`;
const buttonOutlineClass = `${buttonBaseClass} border-border bg-background text-foreground hover:bg-muted`;
const buttonGhostClass = `${buttonBaseClass} px-2.5 text-secondary hover:bg-accent dark:text-primary`;
const cardClass =
  "rounded-lg border border-border bg-card text-card-foreground shadow-[0_20px_70px_rgba(16,32,29,0.07)]";
const flatCardClass = "rounded-lg border border-border bg-background";
const sectionClass = "relative border-t border-border px-4 py-16 sm:px-6 lg:px-14 lg:py-24";
const sectionHeaderClass = "mx-auto grid max-w-3xl gap-3 text-center";
const sectionLabelClass =
  "text-xs font-semibold uppercase tracking-[0.18em] text-secondary dark:text-primary";
const sectionTitleClass =
  "text-balance text-3xl font-semibold leading-tight text-foreground sm:text-4xl lg:text-5xl";
const sectionLeadClass = "text-base leading-7 text-muted-foreground sm:text-lg";
const h3Class = "text-base font-semibold leading-6 text-foreground";
const bodyTextClass = "text-sm leading-6 text-muted-foreground";
const textLinkClass =
  "inline-flex items-center gap-1.5 text-sm font-semibold text-secondary underline-offset-4 transition-colors hover:underline dark:text-primary";
const iconTileClass =
  "flex size-10 shrink-0 items-center justify-center rounded-lg border border-secondary/20 bg-accent text-secondary dark:border-primary/25 dark:bg-primary/10 dark:text-primary";
---

<!doctype html>
<html lang={page.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="pl" href={polishUrl} />
    <link rel="alternate" hreflang="x-default" href={englishUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Solivio" />
    <meta property="og:locale" content={page.locale === "pl" ? "pl_PL" : "en_US"} />
    <meta property="og:title" content={page.ogTitle} />
    <meta property="og:description" content={page.ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={page.ogTitle} />
    <meta name="twitter:description" content={page.ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>
      (() => {
        const storedTheme =
          typeof localStorage !== "undefined" && localStorage.getItem("starlight-theme");
        document.documentElement.dataset.theme = storedTheme === "dark" ? "dark" : "light";
      })();
    </script>
  </head>
  <body class="bg-background font-sans text-foreground antialiased">
    <a
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-primary-foreground"
      href="#main"
    >
      {labels.skipToContent}
    </a>

    <header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur-xl">
      <div class="hidden border-b border-border bg-accent/55 px-4 py-2 text-center text-xs font-medium text-secondary sm:block">
        <a class="inline-flex items-center gap-2 hover:underline" href="/guides/getting-started/">
          <span class="rounded-md bg-secondary px-2 py-0.5 font-mono text-[11px] text-secondary-foreground">
            {releaseLabel}
          </span>
          <span>{labels.announcement}</span>
          <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="grid min-h-16 grid-cols-[auto_1fr_auto] items-center gap-4 px-4 sm:px-6 lg:px-14">
        <a
          class="flex min-w-0 items-center"
          href={page.locale === "pl" ? "/pl/" : "/"}
          aria-label={labels.home}
        >
          <img
            class="h-8 w-auto max-w-[158px] object-contain dark:hidden"
            src="/solivio-logo.png"
            alt="Solivio"
            width="180"
            height="60"
          />
          <img
            class="hidden h-8 w-auto max-w-[158px] object-contain dark:block"
            src="/solivio-logo-dark.png"
            alt="Solivio"
            width="180"
            height="60"
          />
        </a>
        <nav class="hidden items-center justify-center gap-1 md:flex" aria-label={labels.primaryNavigation}>
          <a class="rounded-lg px-3 py-2 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground" href="#workflow">{page.nav.product}</a>
          <a class="rounded-lg px-3 py-2 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground" href="#architecture">{page.nav.architecture}</a>
          <a class="rounded-lg px-3 py-2 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground" href="/guides/">{page.nav.docs}</a>
        </nav>
        <div class="flex items-center gap-2">
          <a
            class="hidden h-9 items-center gap-1.5 rounded-lg border border-border bg-background px-3 text-sm font-semibold text-foreground transition-colors hover:bg-muted sm:inline-flex"
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
            <span>GitHub</span>
          </a>
          <a
            class="hidden h-9 items-center justify-center rounded-lg bg-foreground px-3 text-sm font-semibold text-background transition-colors hover:bg-foreground/85 lg:inline-flex"
            href={page.hero.primary.href}
          >
            {page.hero.primary.label}
          </a>
          <a
            class="inline-flex h-9 items-center justify-center rounded-lg border border-border bg-background px-3 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
            href={page.alternatePath}
            hreflang={page.alternateLabel.toLowerCase()}
          >
            {page.alternateLabel}
          </a>
        </div>
      </div>
    </header>

    <main id="main" class="overflow-clip">
      <section
        class="landing-hero-grid relative px-4 pb-8 pt-12 sm:px-6 sm:pt-16 lg:min-h-[calc(100svh-6.5rem)] lg:px-14 lg:pb-10 lg:pt-20"
        aria-labelledby="landing-title"
      >
        <div class="mx-auto grid max-w-[94rem] items-center gap-10 lg:grid-cols-[minmax(0,0.82fr)_minmax(36rem,1.18fr)] lg:gap-14">
          <div class="grid max-w-3xl gap-6">
            <div
              class="inline-flex w-fit items-center gap-2 rounded-lg border border-border bg-background px-2.5 py-1.5 text-sm font-medium text-muted-foreground shadow-sm"
              data-reveal
            >
              <span class="rounded-md bg-secondary px-2 py-0.5 font-mono text-xs font-semibold text-secondary-foreground">
                {releaseLabel}
              </span>
              <span>{page.hero.facts[0]}</span>
            </div>
            <h1
              id="landing-title"
              class="text-balance text-5xl font-semibold leading-[0.98] text-foreground sm:text-6xl lg:text-7xl"
              data-reveal
              data-reveal-delay="70"
            >
              {page.hero.h1} <span class="text-secondary dark:text-primary">{page.hero.h1Highlight}</span>
            </h1>
            <p
              class="max-w-2xl text-pretty text-base leading-7 text-muted-foreground sm:text-lg"
              data-reveal
              data-reveal-delay="140"
            >
              {page.hero.body}
            </p>
            <div class="flex flex-wrap items-center gap-3" aria-label={labels.primaryActions} data-reveal data-reveal-delay="210">
              <a class={buttonPrimaryClass} href={page.hero.primary.href}>
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
                <span>{page.hero.primary.label}</span>
              </a>
              <a class={buttonOutlineClass} href={page.hero.secondary.href} {...linkAttrs(page.hero.secondary)}>
                <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                </svg>
                {page.hero.secondary.label}
              </a>
              <a class={buttonGhostClass} href={page.hero.tertiary.href} {...linkAttrs(page.hero.tertiary)}>
                {page.hero.tertiary.label}
                <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </a>
            </div>
            <div
              class="grid max-w-2xl overflow-hidden rounded-lg border border-border bg-background shadow-sm"
              data-reveal
              data-reveal-delay="280"
            >
              <div class="flex items-center justify-between gap-3 border-b border-border px-3 py-2">
                <span class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                  {labels.quickStart}
                </span>
                <button
                  class="inline-flex h-7 items-center gap-1.5 rounded-md border border-border px-2 text-xs font-semibold text-secondary transition-colors hover:bg-accent"
                  type="button"
                  data-copy-command={page.hero.quickStart}
                  data-default-label={labels.copy}
                  data-copied-label={labels.copied}
                >
                  <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect width="14" height="14" x="8" y="8" rx="2" />
                    <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
                  </svg>
                  <span data-copy-label>{labels.copy}</span>
                </button>
              </div>
              <p class="overflow-x-auto whitespace-nowrap px-4 py-3 font-mono text-sm leading-6 text-foreground">
                <span class="mr-2 font-semibold text-primary">$</span>{page.hero.quickStart}
              </p>
            </div>
            <ul class="hidden gap-3 sm:grid sm:grid-cols-3" aria-label={labels.projectFacts} data-reveal data-reveal-delay="350">
              {page.hero.facts.map((fact) => (
                <li class="grid grid-cols-[auto_1fr] gap-2 text-sm font-semibold leading-5 text-foreground">
                  <span class="mt-0.5 flex size-5 items-center justify-center rounded-full bg-secondary text-[11px] text-secondary-foreground dark:bg-primary dark:text-primary-foreground" aria-hidden="true">
                    <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  </span>
                  <span>{fact}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="relative" aria-label={labels.productPreview}>
            <div class={`${cardClass} landing-preview-scan overflow-hidden`}>
              <div class="grid min-h-[34rem] lg:grid-cols-[11rem_minmax(0,1fr)]">
                <aside class="hidden border-r border-border bg-sidebar/85 px-4 py-5 text-sm text-sidebar-foreground/75 lg:grid lg:content-start lg:gap-2">
                  <img class="mb-4 h-auto max-w-[104px] dark:hidden" src="/solivio-logo.png" alt="" width="104" height="35" />
                  <img class="mb-4 hidden h-auto max-w-[104px] dark:block" src="/solivio-logo-dark.png" alt="" width="104" height="35" />
                  {page.hero.offerNav.map((label, index) => (
                    index === 2 ? (
                      <strong class="rounded-lg bg-background px-3 py-2.5 font-semibold text-secondary shadow-sm ring-1 ring-border dark:text-primary">
                        {label}
                      </strong>
                    ) : (
                      <span class="rounded-lg px-3 py-2.5 font-semibold">{label}</span>
                    )
                  ))}
                </aside>
                <article class="grid gap-0">
                  <div class="grid border-b border-border md:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
                    <div class="grid gap-4 border-b border-border p-4 md:border-b-0 md:border-r md:p-5">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <h2 class="text-lg font-semibold leading-6 text-foreground">
                            {isPolish ? "Zapytanie" : "Inquiry"}
                          </h2>
                          <p class={bodyTextClass}>#INQ-2026-0607</p>
                        </div>
                        <span class="rounded-md bg-accent px-2 py-1 text-xs font-semibold text-secondary">
                          {isPolish ? "Nowe" : "New"}
                        </span>
                      </div>
                      <div class={`${flatCardClass} p-4`}>
                        <h3 class="text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">
                          {labels.rawInquiry}
                        </h3>
                        <p class="mt-3 text-sm leading-6 text-foreground">
                          {isPolish
                            ? "Potrzebujemy oferty na 3 linie produkcyjne. Każda linia: silnik, przekładnia, sterownik i akcesoria. Dostawa w Q3."
                            : "We need a proposal for 3 production lines. Each line needs a motor, gearbox, drive controller, and accessories. Delivery target: Q3."}
                        </p>
                      </div>
                      <div class={`${flatCardClass} p-4`}>
                        <h3 class="text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">
                          {labels.extractedSummary}
                        </h3>
                        <ul class="mt-3 grid gap-2">
                          {[
                            isPolish ? "3 linie produkcyjne" : "3 production lines",
                            isPolish ? "Silnik + przekładnia + sterownik" : "Motor + gearbox + controller",
                            isPolish ? "Termin dostawy: Q3" : "Delivery target: Q3",
                          ].map((item) => (
                            <li class="grid grid-cols-[auto_1fr] gap-2 text-sm text-foreground">
                              <span class="mt-1.5 size-2 rounded-full bg-secondary dark:bg-primary" aria-hidden="true"></span>
                              <span>{item}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                    <div class="grid gap-4 p-4 md:p-5">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <h2 class="text-lg font-semibold leading-6 text-foreground">{page.hero.offerTitle}</h2>
                          <p class={bodyTextClass}>{page.hero.offerMeta}</p>
                        </div>
