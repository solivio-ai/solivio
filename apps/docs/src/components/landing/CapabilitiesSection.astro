---
import type { LandingContent } from "../../landing/content";
import { ui } from "./shared";

interface Props {
  page: LandingContent;
}

const { page } = Astro.props;
---

<section class="relative border-t border-border px-4 py-16 sm:px-6 lg:px-14 lg:py-24">
  <div class="mx-auto grid max-w-[94rem] gap-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,0.85fr)]">
    <article data-reveal>
      <div class="grid max-w-2xl gap-3">
        <p class={ui.sectionLabelClass}>{page.sectionLabels.foundation}</p>
        <h2 class={ui.sectionTitleClass}>{page.capabilities.title}</h2>
        <p class={ui.sectionLeadClass}>{page.capabilities.body}</p>
      </div>
      <div class="mt-8 grid gap-0 overflow-hidden rounded-lg border border-border bg-background">
        {page.capabilities.items.map((item, index) => (
          <article class="grid grid-cols-[auto_1fr] gap-4 border-b border-border p-4 last:border-b-0 transition-colors hover:bg-muted/45">
            <span class="flex size-11 items-center justify-center rounded-lg border border-secondary/20 bg-accent text-secondary dark:border-primary/25 dark:bg-primary/10 dark:text-primary">
              {index === 0 && (
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 13v8" /><path d="M4 14.9A7 7 0 1 1 15.7 8h1.8a4.5 4.5 0 0 1 2.5 8.2" /><path d="m8 17 4-4 4 4" /></svg>
              )}
              {index === 1 && (
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
              )}
              {index === 2 && (
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M14 2v6h6" /><path d="M8 13h8" /><path d="M8 17h5" /></svg>
              )}
              {index === 3 && (
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" /></svg>
              )}
              {index === 4 && (
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a4 4 0 0 1-4 4H7l-4 4V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z" /></svg>
              )}
              {index > 4 && (
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
              )}
            </span>
            <div>
              <h3 class={ui.h3Class}>{item.title}</h3>
              <p class={ui.bodyTextClass}>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
      <a class={`${ui.textLinkClass} mt-6`} href={page.capabilities.link.href}>
        {page.capabilities.link.label}
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </a>
    </article>

    <article class="self-start rounded-lg border border-border bg-muted/35 p-5 sm:p-7" data-reveal data-reveal-delay="130">
      <p class={ui.sectionLabelClass}>{page.sectionLabels.process}</p>
      <h2 class="mt-3 text-3xl font-semibold leading-tight text-foreground">{page.workflow.title}</h2>
      <p class={`${ui.sectionLeadClass} mt-3`}>{page.workflow.body}</p>
      <ol class="mt-8 grid gap-5">
        {
          page.workflow.steps.map((step, index) => (
            <li class="grid grid-cols-[auto_1fr] gap-4">
              <span class="flex size-9 items-center justify-center rounded-full bg-secondary text-sm font-semibold text-secondary-foreground dark:bg-primary dark:text-primary-foreground">
                {String(index + 1)}
              </span>
              <div class="grid gap-1">
                <h3 class={ui.h3Class}>{step.title}</h3>
                <p class={ui.bodyTextClass}>{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </article>
  </div>
</section>
