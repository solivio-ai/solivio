---
import { githubUrl, type LandingContent } from "../../landing/content";
import { releaseLabel, type LandingLabels } from "./shared";

interface Props {
  page: LandingContent;
  labels: LandingLabels;
}

const { page, labels } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur-xl">
  <div class="hidden border-b border-border bg-accent/55 px-4 py-2 text-center text-xs font-medium text-secondary sm:block">
    <a class="inline-flex items-center gap-2 hover:underline" href="/guides/getting-started/">
      <span class="rounded-md bg-secondary px-2 py-0.5 font-mono text-[11px] text-secondary-foreground">
        {releaseLabel}
      </span>
      <span>{labels.announcement}</span>
      <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>
  </div>
  <div class="mx-auto grid min-h-16 max-w-[94rem] grid-cols-[minmax(0,1fr)_auto] items-center gap-3 px-4 sm:px-6 md:grid-cols-[1fr_auto_1fr] lg:px-14">
    <a
      class="flex min-w-0 items-center justify-self-start"
      href={page.locale === "pl" ? "/pl/" : "/"}
      aria-label={labels.home}
    >
      <img
        class="h-8 w-auto max-w-[132px] object-contain dark:hidden sm:max-w-[158px]"
        src="/solivio-logo.png"
        alt="Solivio"
        width="180"
        height="60"
      />
      <img
        class="hidden h-8 w-auto max-w-[132px] object-contain dark:block sm:max-w-[158px]"
        src="/solivio-logo-dark.png"
        alt="Solivio"
        width="180"
        height="60"
      />
    </a>
    <nav class="hidden items-center justify-self-center gap-1 md:flex" aria-label={labels.primaryNavigation}>
      <a class="rounded-lg px-3 py-2 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground" href="#workflow">{page.nav.product}</a>
      <a class="rounded-lg px-3 py-2 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground" href="#architecture">{page.nav.architecture}</a>
      <a class="rounded-lg px-3 py-2 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground" href="/guides/">{page.nav.docs}</a>
    </nav>
    <div class="flex min-w-0 items-center justify-self-end gap-1.5 sm:gap-2">
      <a
        class="inline-flex size-9 shrink-0 items-center justify-center rounded-lg border border-border bg-background text-foreground transition-colors hover:bg-muted sm:h-9 sm:w-auto sm:gap-1.5 sm:px-3 sm:text-sm sm:font-semibold"
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub repository"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
      <a
        class="hidden h-9 items-center justify-center rounded-lg bg-foreground px-3 text-sm font-semibold text-background transition-colors hover:bg-foreground/85 xl:inline-flex"
        href={page.hero.primary.href}
      >
        {page.hero.primary.label}
      </a>
      <a
        class="inline-flex h-9 min-w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-background px-2 text-sm font-semibold text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        href={page.alternatePath}
        hreflang={page.alternateLabel.toLowerCase()}
      >
        {page.alternateLabel}
      </a>
    </div>
  </div>
</header>
