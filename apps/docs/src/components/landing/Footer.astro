---
import { deraveReferralUrl, githubUrl, type LandingContent } from "../../landing/content";
import { type LandingLabels } from "./shared";

interface Props {
  page: LandingContent;
  labels: LandingLabels;
}

const { page, labels } = Astro.props;
const footerDeraveUrl = deraveReferralUrl(page.locale, "footer_community");
const docsLinks = [
  { href: "/guides/getting-started/", label: page.hero.primary.label },
  { href: "/guides/features/", label: page.capabilities.link.label },
  { href: "/guides/modules/", label: page.architecture.link.label },
  { href: "/guides/extending/", label: page.modules.link.label },
  { href: "/api/", label: labels.apiReference },
];
---

<footer class="border-t border-border bg-sidebar px-4 py-10 text-sidebar-foreground sm:px-6 lg:px-14">
  <div class="mx-auto grid max-w-[94rem] gap-8 md:grid-cols-[minmax(14rem,1.2fr)_repeat(3,minmax(0,1fr))]">
    <div class="grid content-start gap-3">
      <div class="flex flex-wrap items-center gap-3">
        <a href={page.path} aria-label={labels.home}>
          <img class="h-6 w-auto max-w-[112px] object-contain dark:hidden" src="/solivio-logo.png" alt="Solivio" width="180" height="60" />
          <img class="hidden h-6 w-auto max-w-[112px] object-contain dark:block" src="/solivio-logo-dark.png" alt="Solivio" width="180" height="60" />
        </a>
        <span class="text-base font-semibold leading-none text-muted-foreground">{labels.footerBy}</span>
        <a
          class="inline-flex items-center text-foreground transition-colors hover:text-secondary dark:hover:text-primary"
          href={footerDeraveUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Derave"
        >
          <span class="block h-6 aspect-[207/38] bg-current [mask:url(/derave-logo.svg)_center/contain_no-repeat] [-webkit-mask:url(/derave-logo.svg)_center/contain_no-repeat]" aria-hidden="true"></span>
        </a>
      </div>
      <p class="max-w-sm text-sm leading-6 text-muted-foreground">{page.footer.tagline}</p>
    </div>
    <nav class="grid content-start gap-2" aria-label={page.footer.product}>
      <h2 class="text-sm font-semibold text-foreground">{page.footer.product}</h2>
      <a class="text-sm text-muted-foreground hover:text-foreground" href="#workflow">{page.nav.product}</a>
      <a class="text-sm text-muted-foreground hover:text-foreground" href="#architecture">{page.nav.architecture}</a>
    </nav>
    <nav class="grid content-start gap-2" aria-label={page.footer.resources}>
      <h2 class="text-sm font-semibold text-foreground">{page.footer.resources}</h2>
      {docsLinks.map((link) => <a class="text-sm text-muted-foreground hover:text-foreground" href={link.href}>{link.label}</a>)}
    </nav>
    <nav class="grid content-start gap-2" aria-label={page.footer.community}>
      <h2 class="text-sm font-semibold text-foreground">{page.footer.community}</h2>
      <a class="text-sm text-muted-foreground hover:text-foreground" href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a class="text-sm text-muted-foreground hover:text-foreground" href="#main">{labels.footerTop}</a>
    </nav>
  </div>
</footer>
