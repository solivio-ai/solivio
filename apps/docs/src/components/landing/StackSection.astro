---
import type { LandingContent } from "../../landing/content";

interface Props {
  page: LandingContent;
}

const { page } = Astro.props;
---

<section class="border-t border-border bg-muted/35 px-4 py-6 sm:px-6 lg:px-14">
  <div class="mx-auto grid max-w-[94rem] items-start gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(36rem,auto)]">
    <div class="grid gap-3 lg:max-w-xl">
      <h2 class="text-sm font-semibold text-foreground">{page.stack.title}</h2>
      <ul class="flex flex-wrap items-center gap-x-4 gap-y-2">
        {page.stack.items.map((item) => (
          <li class="inline-flex items-center gap-2 text-sm font-medium leading-6 text-muted-foreground">
            <span class="size-1.5 rounded-full bg-secondary/60" aria-hidden="true"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
    <dl class="grid grid-cols-2 self-start overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-4">
      {page.metrics.items.map((item) => (
        <div class="min-w-0 bg-background px-4 py-3">
          <dt class="text-lg font-semibold leading-6 text-foreground">{item.value}</dt>
          <dd class="mt-1 text-[0.68rem] font-medium uppercase leading-4 tracking-[0.12em] text-muted-foreground">
            {item.label}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
