---
import type { LandingContent } from "../../landing/content";
import { type LandingLabels, ui } from "./shared";

interface Props {
  page: LandingContent;
  labels: LandingLabels;
}

const { page, labels } = Astro.props;
const isPolish = page.locale === "pl";
---

<section id="workflow" class={ui.sectionClass}>
  <div class="mx-auto max-w-[94rem]">
    <div class={`${ui.sectionHeaderClass} mb-12`} data-reveal>
      <p class={ui.sectionLabelClass}>{page.locale === "pl" ? "Proces" : "Workflow"}</p>
      <h2 class={ui.sectionTitleClass}>{page.what.title}</h2>
      <p class={ui.sectionLeadClass}>{page.what.body}</p>
    </div>

    <div class={`${ui.cardClass} overflow-hidden`} data-reveal>
      <div class="grid gap-0 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <div class="border-b border-border p-5 sm:p-7 lg:border-b-0 lg:border-r">
          <div class="grid gap-6">
            {page.what.items.map((item, index) => (
              <article class="relative grid grid-cols-[auto_1fr] gap-4">
                {index < page.what.items.length - 1 && (
                  <span class="absolute left-5 top-11 h-[calc(100%+1.5rem)] w-px bg-border" aria-hidden="true"></span>
                )}
                <span class:list={[
                  "z-10 flex size-10 items-center justify-center rounded-full text-sm font-semibold",
                  index === 0 ? "bg-primary text-primary-foreground" : "bg-secondary text-secondary-foreground dark:bg-primary dark:text-primary-foreground",
                ]}>
                  {index + 1}
                </span>
                <div class="grid gap-1.5">
                  <h3 class={ui.h3Class}>{item.title}</h3>
                  <p class={ui.bodyTextClass}>{item.body}</p>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="landing-canvas-grid relative p-5 sm:p-7">
          <div class="grid gap-4">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary dark:text-primary">
                  {labels.sourceTrail}
                </p>
                <h3 class="mt-2 text-2xl font-semibold text-foreground">
                  {isPolish ? "Zapytanie przechodzi przez jawne etapy" : "Inquiry moves through explicit stages"}
                </h3>
              </div>
              <span class="hidden rounded-lg border border-primary/40 bg-primary/15 px-3 py-2 text-sm font-semibold text-foreground sm:inline-flex">
                {labels.confidence} 92%
              </span>
            </div>
            <div class="grid gap-3 md:grid-cols-3">
              {[
                { title: labels.rawInquiry, body: isPolish ? "mail, CSV, dokument" : "email, CSV, document" },
                { title: labels.productMatches, body: isPolish ? "SKU, tekst, semantyka" : "SKU, text, semantic" },
                { title: page.hero.offerStatus, body: isPolish ? "edycja i akceptacja" : "edit and accept" },
              ].map((item, index) => (
                <article class="rounded-lg border border-border bg-background p-4 shadow-sm transition-transform hover:-translate-y-1">
                  <div class="mb-4 flex items-center gap-2">
                    <span class="flex size-7 items-center justify-center rounded-md bg-accent text-xs font-semibold text-secondary">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="h-px flex-1 bg-border"></span>
                  </div>
                  <h4 class="text-sm font-semibold text-foreground">{item.title}</h4>
                  <p class="mt-1 text-sm leading-5 text-muted-foreground">{item.body}</p>
                </article>
              ))}
            </div>
            <div class="rounded-lg border border-border bg-background p-4 shadow-sm">
              <div class="mb-4 flex items-center justify-between gap-3">
                <h4 class="text-sm font-semibold text-foreground">{page.workflow.title}</h4>
                <span class="rounded-md bg-accent px-2 py-1 text-xs font-semibold text-secondary">
                  {page.workflow.steps.length} {isPolish ? "kroków" : "steps"}
                </span>
              </div>
              <div class="grid gap-2">
                {page.workflow.steps.map((step, index) => (
                  <div class="grid grid-cols-[2rem_1fr_auto] items-center gap-3 rounded-md border border-border bg-muted/35 px-3 py-2">
                    <span class="font-mono text-xs font-semibold text-secondary dark:text-primary">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="min-w-0 truncate text-sm font-medium text-foreground">{step.title}</span>
                    <span class="size-2 rounded-full bg-primary" aria-hidden="true"></span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
