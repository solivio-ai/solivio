{
  "name": "@solivio/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0",
    "yarn": ">=4.14.1"
  },
  "scripts": {
    "openapi:generate": "cd ../.. && openapi-gen generate --config openapi-gen.config.ts",
    "dev": "yarn openapi:generate && astro dev --port 4321",
    "build": "yarn openapi:generate && astro build",
    "preview": "astro preview --port 4321",
    "typecheck": "astro check"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/markdown-remark": "^7.1.1",
    "@astrojs/starlight": "^0.38.4",
    "@solivio/theme": "workspace:*",
    "astro": "^6.1.10",
    "starlight-openapi": "^0.25.0",
    "typescript": "^6.0.3"
  }
}
