{
  "name": "@solivio/sdk",
  "version": "0.1.0",
  "description": "Types and helpers for building Solivio modules.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
