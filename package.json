{
  "name": "solivio",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source groundwork for Solivio: customer request intake, product matching, and offer generation.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "sdk",
    "packages/*",
    "apps/*",
    "modules/*"
  ],
  "resolutions": {
    "postcss": "8.5.12"
  },
  "engines": {
    "node": ">=24.15.0",
    "yarn": ">=4.14.1"
  },
  "scripts": {
    "dev": "yarn generate && concurrently -k -n gen,app \"tsx scripts/generate/index.mts --watch\" \"yarn workspace @solivio/app dev\"",
    "generate": "tsx scripts/generate/index.mts",
    "docs:dev": "yarn workspace @solivio/docs dev",
    "docs:build": "yarn generate && yarn workspace @solivio/docs build",
    "openapi:generate": "yarn workspace @solivio/docs openapi:generate",
    "build": "yarn generate && yarn workspace @solivio/app build && yarn workspace @solivio/docs build",
    "check": "biome check . && tsx scripts/check-boundaries.mts",
    "e2e": "playwright test",
    "typecheck": "yarn workspaces foreach -Ap run typecheck",
    "start": "yarn workspace @solivio/app start",
    "setup": "yarn db:up && yarn db:wait && yarn generate && yarn db:migrate",
    "db:up": "docker compose up -d db",
    "db:wait": "node scripts/db-wait.mjs",
    "db:down": "docker compose down",
    "db:check": "yarn workspace @solivio/app db:check",
    "db:generate": "node scripts/db/generate.mjs",
    "db:migrate": "yarn workspace @solivio/app db:migrate",
    "db:studio": "yarn workspace @solivio/app db:studio",
    "benchmark": "yarn workspace @solivio/app benchmark",
    "benchmark:report": "yarn workspace @solivio/app benchmark:report",
    "benchmark:readme": "yarn workspace @solivio/app benchmark:readme",
    "volt": "volt",
    "overlay": "node scripts/overlay.mjs",
    "seed": "tsx scripts/seed.mts",
    "create-module": "node scripts/create-module.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "ensure:local-env": "node scripts/ensure-local-env.mjs",
    "validate": "yarn generate --check && yarn check && yarn typecheck && yarn test",
    "validate:all": "yarn ensure:local-env && yarn install --immutable && yarn dedupe --check && yarn validate && yarn db:check && yarn workspace @solivio/app build && yarn workspace @solivio/docs build && yarn setup && yarn e2e"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/oxide-darwin-arm64": "4.3.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@voltagent/cli": "^0.1.21",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "lightningcss-darwin-arm64": "^1.32.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "zod": "^4.4.3"
  },
  "packageManager": "yarn@4.14.1"
}
