{
  "name": "solivio",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source groundwork for Solivio: customer request intake, product matching, and offer generation.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "sdk",
    "packages/*",
    "apps/*"
  ],
  "resolutions": {
    "postcss": "8.5.12"
  },
  "engines": {
    "node": ">=24.15.0",
    "yarn": ">=4.14.1"
  },
  "scripts": {
    "dev": "yarn workspace @solivio/app dev",
    "docs:dev": "yarn workspace @solivio/docs dev",
    "docs:build": "yarn workspace @solivio/docs build",
    "openapi:generate": "yarn workspace @solivio/docs openapi:generate",
    "build": "yarn workspace @solivio/app build && yarn workspace @solivio/docs build",
    "check": "biome check .",
    "e2e": "playwright test",
    "typecheck": "yarn workspace @solivio/sdk typecheck && yarn workspace @solivio/domain typecheck && yarn workspace @solivio/app typecheck",
    "start": "yarn workspace @solivio/app start",
    "setup": "yarn db:up && yarn db:wait && yarn db:migrate",
    "db:up": "docker compose up -d db",
    "db:wait": "node --env-file=apps/solivio/.env.local scripts/db-wait.mjs",
    "db:down": "docker compose down",
    "db:generate": "yarn workspace @solivio/app db:generate",
    "db:migrate": "yarn workspace @solivio/app db:migrate",
    "db:studio": "yarn workspace @solivio/app db:studio",
    "volt": "volt"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/oxide-darwin-arm64": "4.2.4",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@voltagent/cli": "^0.1.21",
    "lightningcss-darwin-arm64": "^1.32.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  },
  "packageManager": "yarn@4.14.1"
}
